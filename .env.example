# Bright Staffing API Configuration
BRIGHT_API_BASE_URL=https://match.b-bright.be/api
BRIGHT_API_ACCESS_TOKEN=your_api_token_here
BRIGHT_API_VERSION=1.0

# Office ID: single (1), multiple (1,5,7), or all offices (all)
# Office 001 = ID 1 (Oudenaarde, Oost-Vlaanderen), Office 002 = ID 5 (Kuurne, West-Vlaanderen)
BRIGHT_OFFICE_ID=1,5

# Processing Configuration
DRY_RUN=true
BATCH_SIZE=50

# Schedule Configuration (for standalone scheduler)
# Saturday at 08:30 Brussels time
SCHEDULE_TIMEZONE=Europe/Brussels
SCHEDULE_DAY_OF_WEEK=5
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=30

# Telegram Notifications (get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert Configuration
ALERT_ENABLED=false
ALERT_EMAIL_RECIPIENTS=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
